@model IEnumerable<OBeefSoup.Models.JobPosting>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
    var deleteUrl = Url.Action("DeleteAjax", "JobPostings", new { area = "Admin" }) ?? "";
}
<div data-page-size="10">
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0">Vị trí</th>
                            <th class="border-0">Cơ sở</th>
                            <th class="border-0 d-none d-lg-table-cell">Mức lương</th>
                            <th class="border-0 d-none d-md-table-cell">Hạn nộp</th>
                            <th class="border-0">Trạng thái</th>
                            <th class="border-0 d-none d-sm-table-cell">Số đơn</th>
                            <th class="text-end pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr class="no-paginate">
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-briefcase display-4 opacity-25"></i>
                                    <p class="mt-2">Chưa có vị trí tuyển dụng nào</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr data-row-id="job-@item.Id">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Title</div>
                                    <div class="d-lg-none small text-muted">@(string.IsNullOrEmpty(item.SalaryRange) ? "Thỏa thuận" : item.SalaryRange)</div>
                                    <div class="d-sm-none mt-1">
                                        <a asp-controller="CandidateApplications" asp-action="Index" asp-route-jobPostingId="@item.Id"
                                           class="badge bg-primary-subtle text-primary text-decoration-none py-1 px-2 rounded-pill x-small">
                                            @(item.Applications?.Count ?? 0) đơn
                                        </a>
                                    </div>
                                </td>
                                <td><span class="text-dark">@(item.StoreLocation?.Name ?? "Tất cả")</span></td>
                                <td class="d-none d-lg-table-cell"><span class="text-dark">@(string.IsNullOrEmpty(item.SalaryRange) ? "Thỏa thuận" : item.SalaryRange)</span></td>
                                <td class="d-none d-md-table-cell">
                                    @if (item.Deadline.HasValue) {
                                        <span class="@(item.Deadline < DateTime.Now ? "text-danger" : "text-muted") small">
                                            @item.Deadline.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    } else {
                                        <span class="text-muted small">Vô thời hạn</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive) {
                                        <span class="badge bg-success-subtle text-success py-1 px-2 rounded-pill x-small">Hiện</span>
                                    } else {
                                        <span class="badge bg-light text-muted py-1 px-2 rounded-pill x-small">Ẩn</span>
                                    }
                                </td>
                                <td class="d-none d-sm-table-cell">
                                    <a asp-controller="CandidateApplications" asp-action="Index" asp-route-jobPostingId="@item.Id"
                                       class="badge bg-primary-subtle text-primary text-decoration-none py-1 px-2 rounded-pill small">
                                        @(item.Applications?.Count ?? 0) đơn
                                    </a>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border dropdown-toggle no-caret px-2" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm small">
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i>Chỉnh sửa</a></li>
                                            <li><a class="dropdown-item py-2" asp-controller="CandidateApplications" asp-action="Index" asp-route-jobPostingId="@item.Id"><i class="bi bi-people me-2"></i>Xem đơn ứng tuyển</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item py-2 text-danger" href="#"
                                                   onclick="confirmDelete('@deleteUrl?id=@item.Id', '@token', 'job-@item.Id'); return false;">
                                                    <i class="bi bi-trash me-2"></i>Xóa vị trí
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
