@model List<OBeefSoup.Models.MenuItem>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
    var deleteUrl = Url.Action("DeleteAjax", "Menus", new { area = "Admin" }) ?? "";
}
<div data-page-size="20">
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0 d-none d-md-table-cell" style="width:80px">ID</th>
                            <th class="border-0">Tiêu Đề Menu</th>
                            <th class="border-0 d-none d-lg-table-cell">Đường Dẫn (URL)</th>
                            <th class="border-0 d-none d-md-table-cell">Menu Cha</th>
                            <th class="text-center border-0 d-none d-sm-table-cell">Thứ Tự</th>
                            <th class="text-center border-0">Trạng Thái</th>
                            <th class="text-end pe-4 border-0">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Where(m => m.ParentId == null).OrderBy(m => m.DisplayOrder))
                        {
                            <tr class="bg-light bg-opacity-10" data-row-id="menu-@item.Id">
                                <td class="ps-4 d-none d-md-table-cell">@item.Id</td>
                                <td>
                                    <div class="fw-bold text-dark"><i class="bi @(item.Icon ?? "bi-link-45deg") me-2 text-primary"></i>@item.Title</div>
                                    <div class="d-lg-none x-small text-muted"><code>@item.Url</code></div>
                                </td>
                                <td class="d-none d-lg-table-cell"><code>@item.Url</code></td>
                                <td class="d-none d-md-table-cell"><span class="text-muted small">Menu gốc</span></td>
                                <td class="text-center d-none d-sm-table-cell">@item.DisplayOrder</td>
                                <td class="text-center">
                                    <span class="badge @(item.IsActive ? "bg-success-subtle text-success" : "bg-light text-muted") rounded-pill x-small">
                                        @(item.IsActive ? "Hiện" : "Ẩn")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-white border text-danger"
                                                onclick="confirmDelete('@deleteUrl?id=@item.Id', '@token', 'menu-@item.Id'); return false;" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            @foreach (var sub in Model.Where(m => m.ParentId == item.Id).OrderBy(m => m.DisplayOrder))
                            {
                                <tr data-row-id="menu-@sub.Id">
                                    <td class="ps-4 d-none d-md-table-cell text-muted small">@sub.Id</td>
                                    <td class="ps-4 ps-md-5">
                                        <i class="bi bi-arrow-return-right text-muted me-1"></i><span class="small text-dark">@sub.Title</span>
                                        <div class="d-lg-none x-small text-muted ps-3"><code>@sub.Url</code></div>
                                    </td>
                                    <td class="d-none d-lg-table-cell"><code>@sub.Url</code></td>
                                    <td class="d-none d-md-table-cell"><span class="badge bg-info-subtle text-info x-small">@item.Title</span></td>
                                    <td class="text-center d-none d-sm-table-cell small text-muted">@sub.DisplayOrder</td>
                                    <td class="text-center">
                                        <span class="badge @(sub.IsActive ? "bg-success-subtle text-success" : "bg-light text-muted") rounded-pill x-small">
                                            @(sub.IsActive ? "Hiện" : "Ẩn")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@sub.Id" class="btn btn-sm btn-white border" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-sm btn-white border text-danger"
                                                    onclick="confirmDelete('@deleteUrl?id=@sub.Id', '@token', 'menu-@sub.Id'); return false;" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
