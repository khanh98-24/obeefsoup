@model List<OBeefSoup.Models.MenuItem>
@{
    ViewData["Title"] = "Quản Lý Menu";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý Hệ thống Menu</h3>
            <p class="text-muted small mb-0">Thiết lập cấu trúc menu điều hướng cho website.</p>
        </div>
        <div class="d-flex gap-2 w-100 w-md-auto">
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 shadow-sm flex-grow-1 flex-md-grow-0">
                <i class="bi bi-plus-lg"></i> Thêm Menu
            </a>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-white border d-flex align-items-center justify-content-center gap-2 shadow-sm flex-grow-1 flex-md-grow-0">
                <i class="bi bi-arrow-left"></i> <span class="d-none d-sm-inline">Quay lại</span>
            </a>
        </div>
    </div>

    <div id="menusTableContainer">
        @await Html.PartialAsync("_MenusTablePartial", Model)
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
    .x-small { font-size: 0.75rem; }
    .table > :not(caption) > * > * { padding: 1rem 0.75rem; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initClientPagination('menusTableContainer', 20);
        });
    </script>
}
