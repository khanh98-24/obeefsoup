@model List<OBeefSoup.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý đơn hàng</h3>
            <p class="text-muted small mb-0">Theo dõi và xử lý các đơn đặt hàng từ khách hàng.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between w-100 w-lg-auto">
            <form id="ordersFilterForm" class="d-flex flex-column flex-md-row gap-2 align-items-stretch align-items-md-center w-100 w-md-auto">
                <div class="d-flex gap-2">
                    <div class="input-group input-group-sm flex-nowrap">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-event"></i></span>
                        <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control border-start-0" style="min-width:130px;">
                    </div>
                    <div class="input-group input-group-sm flex-nowrap">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-check"></i></span>
                        <input type="date" name="toDate"   value="@ViewBag.ToDate"   class="form-control border-start-0" style="min-width:130px;">
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary shadow-sm btn-sm px-3 flex-grow-1">
                        <i class="bi bi-search me-1"></i> Lọc
                    </button>
                    <button type="button" data-ajax-clear class="btn btn-light shadow-sm border btn-sm flex-grow-1">
                        <i class="bi bi-x-circle me-1"></i> Xóa
                    </button>
                </div>
            </form>
            <div class="d-none d-md-block border-start ps-2">
                <button class="btn btn-white shadow-sm border btn-sm">
                    <i class="bi bi-download me-1"></i> Xuất file
                </button>
            </div>
        </div>
    </div>

    <div id="ordersTableContainer">
        @await Html.PartialAsync("_OrdersTablePartial", Model)
    </div>
</div>

<style>
    .table > :not(caption) > * > * { padding: 1rem 0.75rem; }
    .text-accent { color: var(--accent-color); }
    .mobile-card { background:#fff; border-radius:16px; padding:1.25rem; margin-bottom:1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .x-small { font-size: 0.7rem; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initAjaxSearch('ordersFilterForm', 'ordersTableContainer', '@Url.Action("IndexPartial", "Orders", new { area = "Admin" })');
            initClientPagination('ordersTableContainer', 15);
        });
    </script>
}
