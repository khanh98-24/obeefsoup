@model List<OBeefSoup.Models.Order>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
}

<div data-page-size="15">
    <!-- Desktop Table -->
    <div class="card border-0 shadow-sm overflow-hidden d-none d-lg-block">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0">Mã đơn</th>
                            <th class="border-0">Khách hàng</th>
                            <th class="border-0">Thời gian đặt</th>
                            <th class="border-0">Tổng tiền</th>
                            <th class="border-0">Trạng thái</th>
                            <th class="text-end pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr class="no-paginate">
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox display-4 opacity-25"></i>
                                    <p class="mt-2">Chưa có đơn hàng nào được ghi nhận</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model)
                            {
                                <tr data-row-id="order-@order.OrderId">
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">#@order.OrderNumber</span>
                                    </td>
                                    <td>
                                        <div class="fw-medium text-dark">@order.Customer?.FullName</div>
                                        <small class="text-muted">@order.PhoneNumber</small>
                                    </td>
                                    <td>
                                        <div class="text-dark">@order.OrderDate.ToString("HH:mm, dd/MM/yyyy")</div>
                                    </td>
                                    <td>
                                        <span class="fw-bold text-accent">@order.TotalAmount.ToString("N0")đ</span>
                                    </td>
                                    <td>
                                        @{ RenderStatusBadge(order.Status); }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-area="Admin" asp-action="Details" asp-route-id="@order.OrderId"
                                           class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-card-list d-lg-none">
        @if (Model.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox display-4 opacity-25"></i>
                <p class="mt-2">Chưa có đơn hàng nào</p>
            </div>
        }
        else
        {
            @foreach (var order in Model)
            {
                <div class="mobile-card paginate-item position-relative" data-row-id="order-@order.OrderId">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <span class="badge bg-light text-dark border x-small rounded-pill mb-1">Mã: #@order.OrderNumber</span>
                            <div class="fw-bold fs-5 text-dark">@order.Customer?.FullName</div>
                            <div class="text-muted small"><i class="bi bi-telephone me-1"></i>@order.PhoneNumber</div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-accent fs-5">@order.TotalAmount.ToString("N0")đ</div>
                            <div class="text-muted x-small">@order.OrderDate.ToString("HH:mm, dd/MM")</div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @{ RenderStatusBadge(order.Status); }
                        </div>
                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-primary px-3 shadow-sm rounded-pill">
                            Quản lý <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>

@functions {
    string GetStatusClass(OBeefSoup.Models.OrderStatus status) {
        return status switch {
            OBeefSoup.Models.OrderStatus.Pending    => "bg-warning-subtle text-warning border-warning-subtle",
            OBeefSoup.Models.OrderStatus.Confirmed  => "bg-info-subtle text-info border-info-subtle",
            OBeefSoup.Models.OrderStatus.Preparing  => "bg-primary-subtle text-primary border-primary-subtle",
            OBeefSoup.Models.OrderStatus.Delivering => "bg-secondary-subtle text-secondary border-secondary-subtle",
            OBeefSoup.Models.OrderStatus.Completed  => "bg-success-subtle text-success border-success-subtle",
            OBeefSoup.Models.OrderStatus.Cancelled  => "bg-danger-subtle text-danger border-danger-subtle",
            _                                        => "bg-light text-muted"
        };
    }
    string GetStatusText(OBeefSoup.Models.OrderStatus status) {
        return status switch {
            OBeefSoup.Models.OrderStatus.Pending    => "Chờ xác nhận",
            OBeefSoup.Models.OrderStatus.Confirmed  => "Đã xác nhận",
            OBeefSoup.Models.OrderStatus.Preparing  => "Đang chuẩn bị",
            OBeefSoup.Models.OrderStatus.Delivering => "Đang giao",
            OBeefSoup.Models.OrderStatus.Completed  => "Hoàn thành",
            OBeefSoup.Models.OrderStatus.Cancelled  => "Đã hủy",
            _                                        => status.ToString()
        };
    }
}
@{
    void RenderStatusBadge(OBeefSoup.Models.OrderStatus status) {
        <span class="badge @GetStatusClass(status) border py-1 px-2 rounded-pill small">@GetStatusText(status)</span>
    }
}
