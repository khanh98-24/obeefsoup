@model IEnumerable<OBeefSoup.Models.Category>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
    var deleteUrl = Url.Action("DeleteAjax", "Categories", new { area = "Admin" }) ?? "";
}
<div data-page-size="15">
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0 d-none d-md-table-cell">Thứ tự</th>
                            <th class="border-0">Tên danh mục</th>
                            <th class="border-0 d-none d-lg-table-cell">Mô tả</th>
                            <th class="border-0">Trạng thái</th>
                            <th class="text-end pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr class="no-paginate">
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-folder-x display-4 opacity-25"></i>
                                    <p class="mt-2">Chưa có danh mục nào được tạo</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr data-row-id="category-@item.Id">
                                <td class="ps-4 d-none d-md-table-cell">
                                    <span class="badge bg-light text-dark border fw-normal">@item.DisplayOrder</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Name</div>
                                    <div class="d-lg-none x-small text-muted text-truncate" style="max-width:150px;">@item.Description</div>
                                </td>
                                <td class="d-none d-lg-table-cell">
                                    <span class="text-muted small">@item.Description</span>
                                </td>
                                <td>
                                    @if (item.IsActive) {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 small">Bật</span>
                                    } else {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2 small">Tắt</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-white border text-danger"
                                                onclick="confirmDelete('@deleteUrl?id=@item.Id', '@token', 'category-@item.Id'); return false;"
                                                title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
