@model List<OBeefSoup.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý sản phẩm</h3>
            <p class="text-muted small mb-0">Xem, tìm kiếm và cập nhật các món ăn trong thực đơn của bạn.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
                <i class="bi bi-plus-lg"></i> Thêm sản phẩm mới
            </a>
        </div>
    </div>

    <!-- Search card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form id="productsSearchForm" class="row g-2">
                <div class="col-8 col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control bg-light border-0"
                               placeholder="Tìm tên sản phẩm..." value="@ViewBag.SearchTerm">
                    </div>
                </div>
                <div class="col-4 col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark w-100 px-1">Tìm</button>
                    <button type="button" data-ajax-clear class="btn btn-outline-secondary px-2" title="Xóa tìm kiếm">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="productsTableContainer">
        @await Html.PartialAsync("_ProductsTablePartial", Model)
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .no-caret::after { display: none; }
    .table > :not(caption) > * > * { padding: 1.25rem 0.75rem; }
    .text-accent { color: var(--accent-color); }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initAjaxSearch('productsSearchForm', 'productsTableContainer', '@Url.Action("IndexPartial", "Products", new { area = "Admin" })');
            initClientPagination('productsTableContainer', 10);
        });
    </script>
}
