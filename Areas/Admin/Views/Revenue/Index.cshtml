@using OBeefSoup.Areas.Admin.Controllers
@model RevenueViewModel
@{
    ViewData["Title"] = "Quản lý Doanh thu";
    var fromStr    = Model.FromDate.ToString("yyyy-MM-dd");
    var toStr      = Model.ToDate.ToString("yyyy-MM-dd");
    var searchStr  = Model.Search ?? "";
    var activeRange = (string)(ViewBag.ActiveRange ?? "");
}

<style>
    .rev-stat { border-radius:20px; padding:24px 28px; color:#fff; position:relative; overflow:hidden; border:none; box-shadow:0 10px 30px rgba(0,0,0,.14); transition:transform .2s; }
    .rev-stat:hover { transform:translateY(-3px); }
    .rev-stat::after { content:''; position:absolute; top:-30px; right:-30px; width:110px; height:110px; border-radius:50%; background:rgba(255,255,255,.08); }
    .rev-stat .rs-icon { width:46px; height:46px; border-radius:13px; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; font-size:1.4rem; margin-bottom:14px; }
    .rev-stat .rs-val  { font-size:1.75rem; font-weight:800; line-height:1.1; }
    .rev-stat .rs-lbl  { font-size:.78rem; opacity:.75; margin-top:5px; text-transform:uppercase; letter-spacing:.5px; }
    .bg-rev { background:linear-gradient(135deg,#8B0000,#c0392b) !important; color:#fff !important; }
    .bg-ord { background:linear-gradient(135deg,#1a237e,#3949ab) !important; color:#fff !important; }
    .bg-avg { background:linear-gradient(135deg,#1b5e20,#388e3c) !important; color:#fff !important; }
    .qpill  { padding:7px 16px; border-radius:30px; font-size:.82rem; font-weight:600; border:1.5px solid #dde3ec; background:#fff; color:#555; cursor:pointer; transition:all .2s; white-space:nowrap; }
    .qpill:hover, .qpill.active { background:var(--accent-color); border-color:var(--accent-color); color:#fff; }
    .gtab   { padding:7px 18px; border-radius:30px; font-size:.82rem; font-weight:600; border:1.5px solid #dde3ec; background:#fff; color:#555; cursor:pointer; transition:all .2s; }
    .gtab.active { background:var(--accent-color); border-color:var(--accent-color); color:#fff; }
    .chart-wrapper { position:relative; height:300px; }
    .bm { display:inline-block; padding:4px 11px; border-radius:20px; font-size:.74rem; font-weight:700; }
    .bm-cod   { background:#e8f5e9; color:#2e7d32; }
    .bm-vnpay { background:#e3f2fd; color:#1565c0; }
    .bm-momo  { background:#fce4ec; color:#880e4f; }
    .tp-item { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid rgba(0,0,0,.05); }
    .tp-item:last-child { border-bottom:none; }
    .tp-rank { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.76rem; flex-shrink:0; }
    .r1{background:#fff3cd;color:#856404;} .r2{background:#f0f0f0;color:#444;} .r3{background:#fde8d8;color:#8B4513;} .rn{background:#f4f4f4;color:#999;}
    .rev-table th { font-size:.72rem; text-transform:uppercase; letter-spacing:.5px; color:#8896a5; font-weight:700; padding:13px 14px; border-top:none; }
    .rev-table td { padding:12px 14px; vertical-align:middle; border-color:rgba(0,0,0,.04); font-size:.88rem; }
    .rev-table tbody tr:hover { background:rgba(139,0,0,.025); }
    .rev-page .page-link { border-radius:10px !important; margin:0 2px; border:1.5px solid #eee; color:#444; font-size:.83rem; font-weight:600; padding:6px 12px; }
    .rev-page .page-item.active .page-link { background:var(--accent-color); border-color:var(--accent-color); color:#fff; }
    .rev-page .page-item.disabled .page-link { opacity:.4; }
    /* Loading overlay */
    #revLoading { display:none; position:absolute; inset:0; background:rgba(255,255,255,.6); z-index:10; border-radius:18px; align-items:center; justify-content:center; }
    #revWrapper { position:relative; min-height:200px; }
    .rev-spinner { width:36px; height:36px; border:3px solid #eee; border-top-color:var(--accent-color); border-radius:50%; animation:spin .7s linear infinite; }
    @@keyframes spin { to { transform:rotate(360deg); } }
</style>

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="color:#1e1e2d;">
            <i class="bi bi-graph-up-arrow me-2" style="color:var(--accent-color);"></i>Quản lý Doanh thu
        </h4>
        <p class="text-muted mb-0" style="font-size:.88rem;">Thống kê từ đơn hàng đã hoàn thành</p>
    </div>
    <button class="btn btn-sm btn-outline-secondary d-none d-md-flex align-items-center gap-2" onclick="window.print()">
        <i class="bi bi-printer"></i> In báo cáo
    </button>
</div>

<!-- ===== FILTER BAR ===== -->
<div class="card mb-4" style="border-radius:18px;">
    <div class="card-body p-3 p-md-4">
        <form id="filterForm">
            <input type="hidden" name="groupBy"     id="hGroupBy"     value="@Model.GroupBy">
            <input type="hidden" name="page"        value="1">
            <input type="hidden" name="activeRange" id="hActiveRange" value="@activeRange">
            <input type="hidden" name="search"      value="@searchStr">

            <!-- Quick pills -->
            <div class="d-flex flex-wrap gap-2 mb-3" id="pillBar">
                <span class="text-muted me-1" style="font-size:.8rem;line-height:2.2;">Nhanh:</span>
                <button type="button" class="qpill @(activeRange=="today"   ?"active":"")" data-range="today"   onclick="setRange('today')">Hôm nay</button>
                <button type="button" class="qpill @(activeRange=="week"    ?"active":"")" data-range="week"    onclick="setRange('week')">Tuần này</button>
                <button type="button" class="qpill @(activeRange=="month"   ?"active":"")" data-range="month"   onclick="setRange('month')">Tháng này</button>
                <button type="button" class="qpill @(activeRange=="quarter" ?"active":"")" data-range="quarter" onclick="setRange('quarter')">Quý này</button>
                <button type="button" class="qpill @(activeRange=="year"    ?"active":"")" data-range="year"    onclick="setRange('year')">Năm này</button>
            </div>

            <!-- Date range + groupBy -->
            <div class="row g-2 align-items-end">
                <div class="col-sm-4 col-md-3">
                    <label class="form-label mb-1" style="font-size:.78rem;">Từ ngày</label>
                    <input type="date" name="fromDate" id="inFrom" class="form-control form-control-sm" value="@fromStr">
                </div>
                <div class="col-sm-4 col-md-3">
                    <label class="form-label mb-1" style="font-size:.78rem;">Đến ngày</label>
                    <input type="date" name="toDate" id="inTo" class="form-control form-control-sm" value="@toStr">
                </div>
                <div class="col-sm-4 col-md-6">
                    <label class="form-label mb-1" style="font-size:.78rem;">Nhóm biểu đồ theo</label>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="gtab @(Model.GroupBy=="day"  ?"active":"")" onclick="setGroup('day')">Ngày</button>
                        <button type="button" class="gtab @(Model.GroupBy=="week" ?"active":"")" onclick="setGroup('week')">Tuần</button>
                        <button type="button" class="gtab @(Model.GroupBy=="month"?"active":"")" onclick="setGroup('month')">Tháng</button>
                        <button type="button" class="gtab @(Model.GroupBy=="year" ?"active":"")" onclick="setGroup('year')">Năm</button>
                        <button type="submit" class="btn btn-sm btn-danger ms-auto" style="border-radius:10px;">
                            <i class="bi bi-funnel me-1"></i>Lọc
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ===== DYNAMIC CONTENT (AJAX target) ===== -->
<div id="revWrapper">
    <div id="revLoading" style="display:none;">
        <div class="rev-spinner"></div>
    </div>
    <div id="revMain">
        @await Html.PartialAsync("_RevenueContent", Model)
    </div>
</div>

<script>
// ===== AJAX helpers =====
function revLoad(params, pushState) {
    var qs = new URLSearchParams(params).toString();
    var url = '/Admin/Revenue?' + qs;
    document.getElementById('revLoading').style.display = 'flex';
    fetch(url, { headers: { 'X-Requested-With':'XMLHttpRequest' } })
        .then(function(r){ return r.text(); })
        .then(function(html){
            document.getElementById('revMain').innerHTML = html;
            // Re-run inline scripts inside partial
            document.querySelectorAll('#revMain script').forEach(function(s){
                var ns = document.createElement('script');
                ns.textContent = s.textContent;
                s.parentNode.replaceChild(ns, s);
            });
            document.getElementById('revLoading').style.display = 'none';
            if (pushState) history.pushState(null, '', url);
            bindRevLinks();
        })
        .catch(function(){ document.getElementById('revLoading').style.display = 'none'; });
}

function getFilterParams() {
    return {
        fromDate:    document.getElementById('inFrom').value,
        toDate:      document.getElementById('inTo').value,
        groupBy:     document.getElementById('hGroupBy').value,
        activeRange: document.getElementById('hActiveRange').value,
        page:        1
    };
}

// Filter form AJAX submit
document.getElementById('filterForm').addEventListener('submit', function(e){
    e.preventDefault();
    var p = getFilterParams();
    var sw = document.querySelector('#filterForm [name=search]');
    if (sw) p.search = sw.value;
    revLoad(p, true);
});

// Quick range
function setRange(type) {
    document.querySelectorAll('#pillBar .qpill').forEach(function(b){
        b.classList.toggle('active', b.dataset.range === type);
    });
    document.getElementById('hActiveRange').value = type;
    var now = new Date(), to = now.toISOString().split('T')[0], from;
    if (type==='today')   { from = to; }
    else if (type==='week')    { var d=new Date(now); var dw=d.getDay(); d.setDate(d.getDate()+(dw===0?-6:1-dw)); from=d.toISOString().split('T')[0]; }
    else if (type==='month')   { from=new Date(now.getFullYear(),now.getMonth(),1).toISOString().split('T')[0]; }
    else if (type==='quarter') { var q=Math.floor(now.getMonth()/3); from=new Date(now.getFullYear(),q*3,1).toISOString().split('T')[0]; }
    else                       { from=new Date(now.getFullYear(),0,1).toISOString().split('T')[0]; }
    document.getElementById('inFrom').value = from;
    document.getElementById('inTo').value   = to;
    revLoad({ fromDate:from, toDate:to, groupBy:document.getElementById('hGroupBy').value, activeRange:type, page:1 }, true);
}

function setGroup(g) {
    document.querySelectorAll('.gtab').forEach(function(b){ b.classList.toggle('active', b.textContent.trim().toLowerCase()===g || b.getAttribute('onclick').includes("'"+g+"'")); });
    document.getElementById('hGroupBy').value = g;
    var p = getFilterParams();
    p.groupBy = g;
    var sw = document.querySelector('#filterForm [name=search]');
    if (sw) p.search = sw.value;
    revLoad(p, true);
}

// Search form AJAX submit
function bindRevLinks() {
    // Search form
    var sf = document.getElementById('searchForm');
    if (sf) {
        sf.addEventListener('submit', function(e){
            e.preventDefault();
            var fd = new FormData(sf);
            var p = {};
            fd.forEach(function(v, k){ p[k] = v; });
            revLoad(p, true);
        });
    }

    // Clear search
    window.clearSearch = function() {
        var inp = document.getElementById('searchInput');
        if (inp) inp.value = '';
        var p = getFilterParams();
        p.search = '';
        revLoad(p, true);
    };

    // Pagination links
    document.querySelectorAll('.rev-nav-link').forEach(function(a){
        a.addEventListener('click', function(e){
            e.preventDefault();
            if (a.closest('.page-item.disabled')) return;
            revLoad({
                fromDate:    a.dataset.from,
                toDate:      a.dataset.to,
                groupBy:     a.dataset.group,
                activeRange: a.dataset.range,
                search:      a.dataset.search,
                page:        a.dataset.page
            }, true);
        });
    });
}

bindRevLinks();
</script>
