@using OBeefSoup.Areas.Admin.Controllers
@model RevenueViewModel
@{
    var fromStr   = Model.FromDate.ToString("yyyy-MM-dd");
    var toStr     = Model.ToDate.ToString("yyyy-MM-dd");
    var searchStr = Model.Search ?? "";
    var activeRange = (string)(ViewBag.ActiveRange ?? "");
}

<div id="revContent">
<!-- ===== STAT CARDS ===== -->
<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="rev-stat bg-rev">
            <div class="rs-icon"><i class="bi bi-cash-coin"></i></div>
            <div class="rs-val">@Model.TotalRevenue.ToString("N0")đ</div>
            <div class="rs-lbl">Tổng doanh thu</div>
        </div>
    </div>
    <div class="col-4">
        <div class="rev-stat bg-ord">
            <div class="rs-icon"><i class="bi bi-bag-check-fill"></i></div>
            <div class="rs-val">@Model.TotalOrders</div>
            <div class="rs-lbl">Đơn hoàn thành</div>
        </div>
    </div>
    <div class="col-4">
        <div class="rev-stat bg-avg">
            <div class="rs-icon"><i class="bi bi-receipt"></i></div>
            <div class="rs-val">@Model.AvgOrderValue.ToString("N0")đ</div>
            <div class="rs-lbl">Trung bình/đơn</div>
        </div>
    </div>
</div>

<!-- ===== CHART + TOP PRODUCTS ===== -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100" style="border-radius:18px;">
            <div class="card-header d-flex align-items-center justify-content-between py-3 px-4">
                <span class="fw-bold" style="font-size:.95rem;">
                    <i class="bi bi-bar-chart-fill me-2" style="color:var(--accent-color);"></i>Biểu đồ doanh thu
                </span>
                <span class="text-muted" style="font-size:.75rem;">
                    @Model.FromDate.ToString("dd/MM/yyyy") – @Model.ToDate.ToString("dd/MM/yyyy")
                </span>
            </div>
            <div class="card-body p-3 p-md-4">
                @if (!Model.ChartData.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-graph-up display-4 d-block mb-3 opacity-25"></i>
                        Không có dữ liệu trong khoảng thời gian này
                    </div>
                }
                else
                {
                    <div class="chart-wrapper"><canvas id="revenueChart"></canvas></div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100" style="border-radius:18px;">
            <div class="card-header py-3 px-4">
                <span class="fw-bold" style="font-size:.95rem;">
                    <i class="bi bi-trophy-fill me-2" style="color:#f39c12;"></i>Top sản phẩm
                </span>
            </div>
            <div class="card-body p-3 p-md-4" style="overflow-y:auto;max-height:340px;">
                @if (!Model.TopProducts.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-box display-5 d-block mb-2 opacity-25"></i>Chưa có dữ liệu
                    </div>
                }
                else
                {
                    @for (int i = 0; i < Model.TopProducts.Count; i++)
                    {
                        var p  = Model.TopProducts[i];
                        var rc = i == 0 ? "r1" : i == 1 ? "r2" : i == 2 ? "r3" : "rn";
                        <div class="tp-item">
                            <div class="tp-rank @rc">@(i+1)</div>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate" style="font-size:.86rem;" title="@p.ProductName">@p.ProductName</div>
                                <small class="text-muted">@p.TotalQuantity phần</small>
                            </div>
                            <div class="fw-bold text-end text-danger" style="font-size:.86rem;white-space:nowrap;">@p.TotalRevenue.ToString("N0")đ</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- ===== PAYMENT STATS + ORDER TABLE ===== -->
<div class="row g-3">
    <div class="col-lg-4">
        <div class="card h-100" style="border-radius:18px;">
            <div class="card-header py-3 px-4">
                <span class="fw-bold" style="font-size:.95rem;">
                    <i class="bi bi-credit-card-fill me-2" style="color:#3949ab;"></i>Phương thức thanh toán
                </span>
            </div>
            <div class="card-body p-4">
                @if (!Model.PaymentStats.Any())
                {
                    <div class="text-center text-muted py-4">Không có dữ liệu</div>
                }
                else
                {
                    var maxRev = Model.PaymentStats.Max(x => x.Revenue);
                    @foreach (var ps in Model.PaymentStats.OrderByDescending(x => x.Revenue))
                    {
                        var bc  = ps.Method == "COD" ? "bm-cod" : ps.Method == "VNPAY" ? "bm-vnpay" : "bm-momo";
                        var pct = maxRev > 0 ? (int)(ps.Revenue / maxRev * 100) : 0;
                        var lbl = ps.Method == "COD" ? "Tiền mặt" : ps.Method == "VNPAY" ? "VN Pay" : "Ví MoMo";
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="bm @bc">@lbl</span>
                                <small class="text-muted">@ps.Count đơn</small>
                            </div>
                            <div class="fw-bold mb-2" style="font-size:.92rem;">@ps.Revenue.ToString("N0")đ</div>
                            <div class="progress" style="height:7px;border-radius:4px;background:#f0f0f0;">
                                <div class="progress-bar" style="width:@pct%;background:var(--accent-color);border-radius:4px;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card" style="border-radius:18px;">
            <div class="card-header py-2 px-3">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-bold me-auto" style="font-size:.92rem;">
                        <i class="bi bi-list-check me-1" style="color:var(--accent-color);"></i>Chi tiết đơn hàng
                        <span class="badge bg-secondary rounded-pill ms-1" style="font-size:.72rem;">@Model.TotalOrderCount</span>
                    </span>
                    <!-- Search box -->
                    <form id="searchForm" class="d-flex gap-1" style="min-width:200px;">
                        <input type="hidden" name="fromDate"    value="@fromStr">
                        <input type="hidden" name="toDate"      value="@toStr">
                        <input type="hidden" name="groupBy"     value="@Model.GroupBy">
                        <input type="hidden" name="activeRange" value="@activeRange">
                        <input type="hidden" name="page"        value="1">
                        <div class="input-group input-group-sm">
                            <input type="text" name="search" id="searchInput" class="form-control form-control-sm"
                                   value="@searchStr" placeholder="Mã đơn, tên, SĐT..."
                                   style="border-radius:10px 0 0 10px; font-size:.79rem;">
                            <button class="btn btn-sm btn-outline-secondary" type="submit" style="border-radius:0;">
                                <i class="bi bi-search"></i>
                            </button>
                            @if (!string.IsNullOrEmpty(searchStr))
                            {
                                <a href="#" onclick="clearSearch(); return false;"
                                   class="btn btn-sm btn-outline-danger" style="border-radius:0 10px 10px 0;" title="Xóa">
                                    <i class="bi bi-x"></i>
                                </a>
                            }
                        </div>
                    </form>
                    <!-- Export -->
                    <a href="@Url.Action("ExportXls", new { fromDate=fromStr, toDate=toStr, search=searchStr })"
                       class="btn btn-sm btn-success d-flex align-items-center gap-1"
                       style="border-radius:10px; font-size:.8rem;">
                        <i class="bi bi-file-earmark-excel"></i>
                        <span class="d-none d-md-inline">Xuất Excel</span>
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (!Model.Orders.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
                        @(string.IsNullOrEmpty(searchStr) ? "Không có đơn hàng" : $"Không tìm thấy đơn khớp \"{searchStr}\"")
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table rev-table mb-0">
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th class="d-none d-md-table-cell">Ngày</th>
                                    <th>Thanh toán</th>
                                    <th class="text-end">Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in Model.Orders)
                                {
                                    var met = o.PaymentMethod == "COD" ? "Tiền mặt" : o.PaymentMethod == "VNPAY" ? "VN Pay" : "Ví MoMo";
                                    var mc  = o.PaymentMethod == "COD" ? "bm-cod"   : o.PaymentMethod == "VNPAY" ? "bm-vnpay" : "bm-momo";
                                    <tr>
                                        <td><strong class="text-primary" style="font-size:.82rem;">@o.OrderNumber</strong></td>
                                        <td>
                                            <div style="font-size:.86rem;">@o.Customer?.FullName</div>
                                            <small class="text-muted">@o.PhoneNumber</small>
                                        </td>
                                        <td class="d-none d-md-table-cell"><small class="text-muted">@o.OrderDate.ToString("dd/MM/yy HH:mm")</small></td>
                                        <td><span class="bm @mc">@met</span></td>
                                        <td class="text-end fw-bold text-danger">@o.TotalAmount.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.TotalPages > 1 || !string.IsNullOrEmpty(searchStr))
                    {
                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top">
                            <small class="text-muted" style="font-size:.78rem;">
                                @if (!string.IsNullOrEmpty(searchStr)) { <span>Tìm: "<strong>@searchStr</strong>" · </span> }
                                Trang @Model.CurrentPage/@Model.TotalPages · @Model.TotalOrderCount đơn
                            </small>
                            @if (Model.TotalPages > 1)
                            {
                                <nav><ul class="pagination rev-page mb-0">
                                    <li class="page-item @(Model.CurrentPage<=1?"disabled":"")">
                                        <a class="page-link rev-nav-link"
                                           data-from="@fromStr" data-to="@toStr" data-group="@Model.GroupBy"
                                           data-range="@activeRange" data-search="@searchStr"
                                           data-page="@(Model.CurrentPage-1)" href="#">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                    @{
                                        int pStart = Math.Max(1, Model.CurrentPage - 2);
                                        int pEnd   = Math.Min(Model.TotalPages, pStart + 4);
                                    }
                                    @for (int pg = pStart; pg <= pEnd; pg++)
                                    {
                                        <li class="page-item @(pg==Model.CurrentPage?"active":"")">
                                            <a class="page-link rev-nav-link"
                                               data-from="@fromStr" data-to="@toStr" data-group="@Model.GroupBy"
                                               data-range="@activeRange" data-search="@searchStr"
                                               data-page="@pg" href="#">@pg</a>
                                        </li>
                                    }
                                    <li class="page-item @(Model.CurrentPage>=Model.TotalPages?"disabled":"")">
                                        <a class="page-link rev-nav-link"
                                           data-from="@fromStr" data-to="@toStr" data-group="@Model.GroupBy"
                                           data-range="@activeRange" data-search="@searchStr"
                                           data-page="@(Model.CurrentPage+1)" href="#">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul></nav>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
</div><!-- #revContent -->

<script>
(function(){
    if (!window._chartJsLoaded && typeof Chart === 'undefined') {
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
        s.onload = function(){ window._chartJsLoaded = true; initChart(); };
        document.head.appendChild(s);
    } else {
        initChart();
    }

    function initChart() {
        var ctx = document.getElementById('revenueChart'); if (!ctx) return;
        if (window._revChart) { window._revChart.destroy(); window._revChart = null; }
        var labels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(x => x.Label)));
        var revenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(x => x.Revenue)));
        var orders  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(x => x.Orders)));
        if (!labels || !labels.length) return;
        window._revChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    { label:'Doanh thu', data:revenue, backgroundColor:'rgba(139,0,0,0.72)', borderRadius:7, yAxisID:'y' },
                    { label:'Số đơn', data:orders, type:'line', borderColor:'#3949ab', backgroundColor:'rgba(57,73,171,.08)',
                      borderWidth:2.5, pointRadius:4, pointBackgroundColor:'#3949ab', tension:0.4, fill:true, yAxisID:'y1' }
                ]
            },
            options: {
                responsive:true, maintainAspectRatio:false,
                interaction:{ mode:'index', intersect:false },
                plugins:{
                    legend:{ position:'top', labels:{ font:{size:11} } },
                    tooltip:{ callbacks:{ label:function(c) {
                        if(c.datasetIndex===0) return ' Doanh thu: '+Number(c.raw).toLocaleString('vi-VN')+'đ';
                        return ' Số đơn: '+c.raw;
                    }}}
                },
                scales:{
                    x:{ grid:{display:false}, ticks:{font:{size:11}} },
                    y:{ position:'left', grid:{color:'rgba(0,0,0,.04)'},
                        ticks:{font:{size:10},callback:function(v){return v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'k':v;}} },
                    y1:{ position:'right', grid:{drawOnChartArea:false}, ticks:{font:{size:10},stepSize:1} }
                }
            }
        });
    }
})();
</script>
