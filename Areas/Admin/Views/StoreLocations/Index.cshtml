@model IEnumerable<OBeefSoup.Models.StoreLocation>
@{
    ViewData["Title"] = "Quản lý cơ sở";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý cơ sở</h3>
            <p class="text-muted small mb-0">Danh sách các chi nhánh nhà hàng hiển thị trên website.</p>
        </div>
        <div class="w-100 w-md-auto">
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 shadow-sm w-100 w-md-auto">
                <i class="bi bi-geo-alt"></i> Thêm cơ sở mới
            </a>
        </div>
    </div>

    <div id="storeLocationsContainer">
        @await Html.PartialAsync("_StoreLocationsTablePartial", Model)
    </div>
</div>

<style>
    .store-card { transition: transform 0.2s; }
    .store-card:hover { transform: translateY(-5px); }
    .store-card.inactive { opacity: 0.7; }
    .x-small { font-size: 0.7rem; }
    .no-caret::after { display: none; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initClientPagination('storeLocationsContainer', 6);
        });
    </script>
}
