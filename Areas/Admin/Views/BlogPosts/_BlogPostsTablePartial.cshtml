@model IEnumerable<OBeefSoup.Models.BlogPost>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
    var deleteUrl = Url.Action("DeleteAjax", "BlogPosts", new { area = "Admin" }) ?? "";
}
<div data-page-size="10">
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0">Thông tin bài viết</th>
                            <th class="border-0">Trạng thái</th>
                            <th class="border-0 d-none d-md-table-cell">Ngày đăng</th>
                            <th class="text-end pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr class="no-paginate">
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-journal-x display-4 opacity-25"></i>
                                    <p class="mt-2 text-muted">Chưa có bài viết nào được tạo</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr data-row-id="blogpost-@item.Id">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Title"
                                                 class="rounded-3 shadow-sm d-none d-sm-block"
                                                 style="width:70px;height:45px;object-fit:cover;border:1px solid #eee;" />
                                        }
                                        <div>
                                            <div class="fw-bold text-dark text-truncate" style="max-width:200px;">@item.Title</div>
                                            <div class="d-md-none x-small text-muted">@item.CreatedDate.ToString("dd/MM/yyyy")</div>
                                            <div class="d-none d-md-block text-muted small">@item.Slug</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.IsActive) {
                                        <span class="badge bg-success-subtle text-success py-1 px-2 rounded-pill x-small">Hiện</span>
                                    } else {
                                        <span class="badge bg-light text-muted py-1 px-2 rounded-pill x-small">Ẩn</span>
                                    }
                                </td>
                                <td class="d-none d-md-table-cell">
                                    <div class="text-dark small">@item.CreatedDate.ToString("dd/MM/yyyy")</div>
                                    <small class="text-muted x-small">@item.CreatedDate.ToString("HH:mm")</small>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border no-caret px-2" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm small">
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i>Chỉnh sửa</a></li>
                                            <li>
                                                <a class="dropdown-item py-2 text-danger" href="#"
                                                   onclick="confirmDelete('@deleteUrl?id=@item.Id', '@token', 'blogpost-@item.Id'); return false;">
                                                    <i class="bi bi-trash me-2"></i>Xóa bài viết
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
