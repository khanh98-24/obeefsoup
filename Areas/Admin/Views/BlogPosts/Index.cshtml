@model IEnumerable<OBeefSoup.Models.BlogPost>
@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý bài viết</h3>
            <p class="text-muted small mb-0">Viết và quản lý các bài blog, tin tức khuyến mãi.</p>
        </div>
        <div class="w-100 w-md-auto">
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 shadow-sm w-100 w-md-auto">
                <i class="bi bi-pencil-square"></i> Viết bài mới
            </a>
        </div>
    </div>

    <!-- Search -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form id="blogPostsSearchForm" class="row g-2">
                <div class="col-8 col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control bg-light border-0"
                               placeholder="Tìm tiêu đề bài viết..." value="@ViewBag.SearchTerm">
                    </div>
                </div>
                <div class="col-4 col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark w-100 px-1">Tìm</button>
                    <button type="button" data-ajax-clear class="btn btn-outline-secondary px-2" title="Xóa tìm kiếm">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="blogPostsTableContainer">
        @await Html.PartialAsync("_BlogPostsTablePartial", Model)
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
    .no-caret::after { display: none; }
    .table > :not(caption) > * > * { padding: 1rem 0.75rem; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initAjaxSearch('blogPostsSearchForm', 'blogPostsTableContainer', '@Url.Action("IndexPartial", "BlogPosts", new { area = "Admin" })');
            initClientPagination('blogPostsTableContainer', 10);
        });
    </script>
}
