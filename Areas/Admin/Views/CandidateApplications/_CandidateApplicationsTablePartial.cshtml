@model List<OBeefSoup.Models.CandidateApplication>
@{
    var token = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
                    ?.GetAndStoreTokens(Context).RequestToken ?? "";
    var deleteUrl = Url.Action("DeleteAjax", "CandidateApplications", new { area = "Admin" }) ?? "";
}
<div data-page-size="10">
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr class="text-muted small">
                            <th class="ps-4 border-0">Ứng viên</th>
                            <th class="border-0">Vị trí</th>
                            <th class="border-0 d-none d-md-table-cell">Ngày nộp</th>
                            <th class="border-0">Trạng thái</th>
                            <th class="text-end pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr class="no-paginate">
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-person-badge display-4 opacity-25"></i>
                                    <p class="mt-2">Chưa có hồ sơ ứng tuyển nào</p>
                                </td>
                            </tr>
                        }
                        @foreach (var app in Model)
                        {
                            var statusClass = app.Status switch {
                                OBeefSoup.Models.ApplicationStatus.Pending      => "bg-warning-subtle text-warning",
                                OBeefSoup.Models.ApplicationStatus.Reviewed     => "bg-info-subtle text-info",
                                OBeefSoup.Models.ApplicationStatus.Interviewing => "bg-primary-subtle text-primary",
                                OBeefSoup.Models.ApplicationStatus.Hired        => "bg-success-subtle text-success",
                                OBeefSoup.Models.ApplicationStatus.Rejected     => "bg-danger-subtle text-danger",
                                _ => "bg-light text-muted"
                            };
                            var statusText = app.Status switch {
                                OBeefSoup.Models.ApplicationStatus.Pending      => "Chờ duyệt",
                                OBeefSoup.Models.ApplicationStatus.Reviewed     => "Đã xem hồ sơ",
                                OBeefSoup.Models.ApplicationStatus.Interviewing => "Đang phỏng vấn",
                                OBeefSoup.Models.ApplicationStatus.Hired        => "Đã tuyển",
                                OBeefSoup.Models.ApplicationStatus.Rejected     => "Từ chối",
                                _ => app.Status.ToString()
                            };
                            <tr data-row-id="app-@app.Id">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@app.FullName</div>
                                    <div class="text-muted small">@app.Email</div>
                                </td>
                                <td><span class="text-dark small">@app.JobPosting?.Title</span></td>
                                <td class="d-none d-md-table-cell">
                                    <div class="text-dark small">@app.AppliedDate.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td>
                                    <span class="badge @statusClass py-1 px-2 rounded-pill x-small">@statusText</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-white border">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button class="btn btn-sm btn-white border text-danger"
                                                onclick="confirmDelete('@deleteUrl?id=@app.Id', '@token', 'app-@app.Id'); return false;"
                                                title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
