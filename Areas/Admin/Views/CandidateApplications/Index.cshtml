@model IEnumerable<OBeefSoup.Models.CandidateApplication>
@{
    ViewData["Title"] = "Quản lý hồ sơ ứng tuyển";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0">Hồ sơ ứng tuyển</h3>
            @if (ViewBag.JobTitle != null)
            {
                <p class="text-muted small mb-0">Đang lọc theo vị trí: <strong>@ViewBag.JobTitle</strong></p>
            }
            else
            {
                <p class="text-muted small mb-0">Tất cả đơn ứng tuyển từ ứng viên.</p>
            }
        </div>
        <div>
            <a asp-action="Index" class="btn btn-light border shadow-sm">
                <i class="bi bi-arrow-left me-1"></i>Tất cả
            </a>
        </div>
    </div>

    <div id="candidateApplicationsTableContainer">
        @await Html.PartialAsync("_CandidateApplicationsTablePartial", Model.ToList())
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
    .btn-white { background: #fff; }
    .table > :not(caption) > * > * { padding: 1rem 0.75rem; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initClientPagination('candidateApplicationsTableContainer', 10);
        });
    </script>
}
