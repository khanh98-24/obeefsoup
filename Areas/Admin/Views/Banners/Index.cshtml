@model List<OBeefSoup.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0">Quản lý Banner</h3>
            <p class="text-muted small mb-0">Quản lý các hình ảnh quảng cáo hiển thị trên trang chủ.</p>
        </div>
        <div class="w-100 w-md-auto">
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 shadow-sm w-100 w-md-auto">
                <i class="bi bi-plus-lg"></i> Thêm Banner mới
            </a>
        </div>
    </div>

    <div id="bannersContainer">
        @await Html.PartialAsync("_BannersTablePartial", Model)
    </div>
</div>

<style>
    .banner-card { transition: transform 0.2s; }
    .banner-card:hover { transform: translateY(-5px); }
    .banner-card.inactive { opacity: 0.75; }
    .no-caret::after { display: none; }
    @@media (max-width: 768px) {
        .banner-card img { height: 180px !important; }
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initClientPagination('bannersContainer', 8);
        });
    </script>
}
